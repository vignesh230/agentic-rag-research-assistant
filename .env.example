# Copy to .env and fill in real values

# Database (matches docker-compose defaults)
POSTGRES_DSN=postgresql://rag:rag@localhost:5432/ragdb

# Embedding model (sentence-transformers hub name)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Chunking
CHUNK_STRATEGY=recursive   # fixed | sentence | recursive
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval
TOP_K=5

# Generation — pick one provider
LLM_PROVIDER=nvidia            # anthropic | nvidia

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# NVIDIA NIM (used when LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

MAX_CRITIC_LOOPS=3

# Service
RAG_MODE=naive             # naive | reranked | agentic
LOG_LEVEL=INFO
